<IfModule mod_rewrite.c>
    RewriteEngine On

    # Redirecionar para HTTPS em producao
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP_HOST} gpsimports\.com\.br [NC]
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Servir arquivos estaticos da pasta public
    RewriteRule ^(uploads/.*)$ public/$1 [L]
    RewriteRule ^(assets/.*)$ public/$1 [L]

    # Redirecionar tudo para public/index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/index.php [L,QSA]
</IfModule>

# Proteger arquivos sensiveis
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

<FilesMatch "(composer\.(json|lock)|\.env|phpunit\.xml)$">
    Require all denied
</FilesMatch>
